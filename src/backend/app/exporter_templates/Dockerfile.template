# Foundry Hosted Agent — single-stage container for ${name}
#
# Built by Kratos's "Download as Foundry Agent" exporter.
# Mirrors the pattern used by Kratos's own src/hosted-agent/Dockerfile —
# UV + Python 3.12 + Node.js (for bundled stdio MCP mock servers, if any).

FROM python:3.12-slim AS base

# uv via the official static binary (matches Kratos host runtime)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# System deps:
#   * curl       — for NodeSource installer + healthcheck
#   * nodejs/npm — only needed when bundled stdio MCP servers exist under mocks/
#                  (no-op cost when not used; keeps the image self-contained)
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl ca-certificates gnupg \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Install Python deps first so the layer caches across iterations.
COPY pyproject.toml ./
RUN uv sync --no-dev

# Bundled MCP mock servers (one folder per npm package).
# The directory may be empty for use-cases that don't use any local MCP
# server — the conditional install handles both cases cleanly.
COPY mocks/ ./mocks/
RUN if ls ./mocks/packages/*/package.json >/dev/null 2>&1; then \
        npm install -g ./mocks/packages/*; \
    fi

# Skills, system prompt, MCP config, agent runtime, etc.
COPY . .

EXPOSE 8088

# uv-managed venv is at /app/.venv; uv run picks it up.
CMD ["uv", "run", "python", "main.py"]
