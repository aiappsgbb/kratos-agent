[project]
name = "${slug}"
version = "0.1.0"
description = "${description}"
requires-python = ">=3.11"
dependencies = [
    # Microsoft Foundry agent host
    "azure-ai-agentserver-invocations~=1.0.0b4",
    "azure-identity~=1.25.3",
    # Application Insights / OpenTelemetry (no-op when unconfigured)
    "azure-monitor-opentelemetry>=1.6.4",
    "opentelemetry-sdk>=1.27.0",
    "opentelemetry-instrumentation-logging>=0.48b0",
    # GitHub Copilot SDK (the actual agent runtime + tools + MCP wiring)
    "github-copilot-sdk~=1.0.0",
    # Local-dev convenience
    "python-dotenv~=1.0.0",
]

[tool.uv]
# azure-ai-agentserver-invocations is a beta; allow beta resolutions only when
# strictly required (avoids dragging beta azure-identity in for the GA flows).
prerelease = "if-necessary-or-explicit"
