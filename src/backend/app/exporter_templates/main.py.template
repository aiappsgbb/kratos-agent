"""Foundry Hosted Agent — Kratos use-case standalone runtime (exported).

This file is shipped inside every ZIP produced by Kratos's
``GET /api/use-cases/{use_case}/export`` endpoint. It is a **single-tenant**
adaptation of Kratos's multi-tenant ``src/hosted-agent/main.py`` — it
intentionally does not depend on the Kratos backend (no Cosmos, no Blob, no
SkillRegistry classes). All state lives next to this file on disk:

    /app/copilot-instructions.md     ← system prompt (from SYSTEM_PROMPT.md)
    /app/skills/<name>/SKILL.md      ← skill files (frontmatter + body)
    /app/skills/<name>/scripts/...   ← optional skill scripts / assets
    /app/mcp-config.json             ← MCP server map (dict format)

Auth modes (selected automatically):
  * BYOK Foundry:  FOUNDRY_PROJECT_ENDPOINT or AZURE_AI_PROJECT_ENDPOINT +
                   MODEL_DEPLOYMENT_NAME  →  DefaultAzureCredential
                   Token scope: https://ai.azure.com/.default
  * GitHub Copilot: GITHUB_TOKEN set → GitHub-hosted models (local dev only)

Serves a Copilot SDK agent via ``InvocationAgentServerHost`` on port 8088 —
``/invocations`` only (no ``/responses``). The Foundry platform injects
``FOUNDRY_AGENT_SESSION_ID`` so the SDK session is resumed across calls.
"""

from __future__ import annotations

import asyncio
import contextlib
import json
import logging
import os
import pathlib
import sys
import time
from typing import Any

from azure.ai.agentserver.invocations import InvocationAgentServerHost
from copilot import CopilotClient
from copilot.generated.session_events import SessionEventType
from copilot.session import PermissionHandler, ProviderConfig
from dotenv import load_dotenv
from starlette.requests import Request
from starlette.responses import JSONResponse, Response, StreamingResponse

load_dotenv()

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(levelname)s %(name)s: %(message)s",
)
logger = logging.getLogger(__name__)

# ---------------------------------------------------------------------------
# Application Insights / OpenTelemetry tracing
# ---------------------------------------------------------------------------
# Honour both env-var spellings; set both so the Foundry platform and the
# azure-monitor SDK both find the connection string.

_APPINSIGHTS_CS = (
    os.getenv("APPLICATIONINSIGHTS_CONNECTION_STRING", "").strip()
    or os.getenv("APPLICATION_INSIGHTS_CONNECTION_STRING", "").strip()
)
if _APPINSIGHTS_CS:
    os.environ.setdefault("APPLICATIONINSIGHTS_CONNECTION_STRING", _APPINSIGHTS_CS)
    os.environ.setdefault("APPLICATION_INSIGHTS_CONNECTION_STRING", _APPINSIGHTS_CS)
    try:
        from azure.monitor.opentelemetry import configure_azure_monitor

        configure_azure_monitor(connection_string=_APPINSIGHTS_CS, logger_name="hosted-agent")
        logger.info("Azure Monitor configured")
    except Exception as exc:  # noqa: BLE001 — telemetry must not break the agent
        logger.warning("configure_azure_monitor failed (platform may handle it): %s", exc)
else:
    logger.info("No AppInsights connection string — tracing disabled")

# ---------------------------------------------------------------------------
# Base directory
# ---------------------------------------------------------------------------

BASE_DIR = pathlib.Path(os.getenv("PROJECT_DIR", "/app")).resolve()

# ---------------------------------------------------------------------------
# BYOK Authentication
# ---------------------------------------------------------------------------
# Token scope is ``https://ai.azure.com/.default`` (renamed from
# cognitiveservices.azure.com in May 2026). The SDK appends the API-version
# query param when ``type="azure"`` — do NOT append ``/openai/v1/`` to the
# endpoint URL.

_BYOK_CREDENTIAL: Any = None
_BYOK_ENDPOINT = ""
_MODEL = (
    os.getenv("MODEL_DEPLOYMENT_NAME", "")
    or os.getenv("AZURE_AI_MODEL_DEPLOYMENT_NAME", "")
    or os.getenv("FOUNDRY_MODEL_DEPLOYMENT", "")
)


def _init_byok() -> bool:
    """Initialise the BYOK credential. Returns False if BYOK is not configured."""
    global _BYOK_CREDENTIAL, _BYOK_ENDPOINT
    endpoint = (
        os.getenv("FOUNDRY_PROJECT_ENDPOINT", "").strip().rstrip("/")
        or os.getenv("AZURE_AI_PROJECT_ENDPOINT", "").strip().rstrip("/")
    )
    if not endpoint or not _MODEL:
        return False
    try:
        from azure.identity import DefaultAzureCredential

        _BYOK_CREDENTIAL = DefaultAzureCredential()
        _BYOK_ENDPOINT = endpoint
        token = _BYOK_CREDENTIAL.get_token("https://ai.azure.com/.default")
        logger.info(
            "BYOK verified: %s (model=%s, token expires in %ds)",
            endpoint,
            _MODEL,
            int(token.expires_on - time.time()),
        )
        return True
    except Exception as exc:  # noqa: BLE001
        logger.error("BYOK init failed: %s", exc)
        return False


def _get_provider() -> ProviderConfig | None:
    """Mint a fresh BYOK ProviderConfig. Returns None when BYOK is not configured."""
    if not _BYOK_CREDENTIAL or not _BYOK_ENDPOINT:
        return None
    try:
        token = _BYOK_CREDENTIAL.get_token("https://ai.azure.com/.default").token
        return ProviderConfig(
            type="azure",
            base_url=_BYOK_ENDPOINT,
            wire_api="responses",
            bearer_token=token,
        )
    except Exception as exc:  # noqa: BLE001
        logger.error("BYOK token mint failed: %s", exc)
        return None


# ---------------------------------------------------------------------------
# Instructions, skills, MCP
# ---------------------------------------------------------------------------

_FRONTMATTER_DELIM = "---"


def _strip_frontmatter(text: str) -> str:
    """Drop a leading YAML frontmatter block, keep the body untouched."""
    lines = text.splitlines()
    if not lines or lines[0].strip() != _FRONTMATTER_DELIM:
        return text
    for i in range(1, len(lines)):
        if lines[i].strip() == _FRONTMATTER_DELIM:
            return "\n".join(lines[i + 1 :]).lstrip()
    return text


def _load_instructions() -> str:
    """Load the system prompt from copilot-instructions.md (frontmatter stripped)."""
    ci = BASE_DIR / "copilot-instructions.md"
    if not ci.exists():
        return ""
    return _strip_frontmatter(ci.read_text(encoding="utf-8")).strip()


def _load_mcp_servers() -> dict | None:
    """Load MCP servers from mcp-config.json next to this file.

    The file mirrors Kratos's ``.mcp.json`` dict shape:

        {
          "sap-s4": {"type": "local", "command": "sap-s4-mcp-server",
                     "args": [], "tools": ["*"]},
          "kb":     {"type": "http",  "url": "https://kb.example/mcp",
                     "tools": ["*"]}
        }

    ``${ENV_VAR}`` references inside string values are expanded against the
    current environment so deployments can wire URLs / tokens via env-vars.
    """
    cfg_path = BASE_DIR / "mcp-config.json"
    if not cfg_path.exists():
        return None
    try:
        raw = cfg_path.read_text(encoding="utf-8")
    except OSError as exc:
        logger.warning("Could not read %s: %s", cfg_path, exc)
        return None

    expanded = os.path.expandvars(raw)
    try:
        servers: dict = json.loads(expanded)
    except json.JSONDecodeError as exc:
        logger.warning("Invalid mcp-config.json: %s", exc)
        return None
    return servers or None


# ---------------------------------------------------------------------------
# Session Management
# ---------------------------------------------------------------------------

app = InvocationAgentServerHost()

_client: CopilotClient | None = None
_session: Any = None


async def _ensure_session() -> None:
    """Create or resume a CopilotClient session. Lazy — runs once per worker."""
    global _client, _session
    if _session is not None:
        return

    session_id = os.environ.get("FOUNDRY_AGENT_SESSION_ID", "")
    provider = _get_provider()
    github_token = os.environ.get("GITHUB_TOKEN", "")

    if provider:
        # BYOK path: provider config supplied at session creation; no token here.
        _client = CopilotClient()
    elif github_token:
        # GitHub-hosted models (dev fallback): github_token is a top-level
        # kwarg on CopilotClient since github-copilot-sdk 1.0.0 GA.
        _client = CopilotClient(github_token=github_token)
    else:
        raise RuntimeError(
            "No auth configured. Set FOUNDRY_PROJECT_ENDPOINT + MODEL_DEPLOYMENT_NAME "
            "(BYOK Foundry) or GITHUB_TOKEN (GitHub Copilot)."
        )

    await _client.start()
    logger.info("CopilotClient started (mode=%s)", "BYOK" if provider else "GITHUB_TOKEN")

    kwargs: dict[str, Any] = {
        "on_permission_request": PermissionHandler.approve_all,
        "streaming": True,
        "working_directory": str(pathlib.Path.home()),
        "provider": provider,
        "model": _MODEL or None,
    }

    instructions = _load_instructions()
    if instructions:
        kwargs["system_message"] = {"mode": "replace", "content": instructions}

    skills_dir = BASE_DIR / "skills"
    if skills_dir.is_dir():
        kwargs["skill_directories"] = [str(skills_dir)]

    mcp = _load_mcp_servers()
    if mcp:
        kwargs["mcp_servers"] = mcp

    try:
        if session_id:
            _session = await _client.resume_session(session_id, **kwargs)
            logger.info("Resumed session: %s", session_id)
        else:
            raise RuntimeError("no session_id")
    except Exception:  # noqa: BLE001 — fall back to a fresh session
        _session = await _client.create_session(**kwargs)
        logger.info("Created new session")


# ---------------------------------------------------------------------------
# SSE Streaming Handler
# ---------------------------------------------------------------------------


async def _stream_response(invocation_id: str, input_text: str):
    """Stream CopilotClient events as SSE, logging tool-call starts."""
    await _ensure_session()
    queue: asyncio.Queue = asyncio.Queue()

    def on_event(event: Any) -> None:
        if event.type == SessionEventType.SESSION_IDLE:
            queue.put_nowait(None)
        elif event.type == SessionEventType.SESSION_ERROR:
            queue.put_nowait(RuntimeError(getattr(event.data, "message", "error")))
        else:
            queue.put_nowait(event)

    unsubscribe = _session.on(on_event)
    try:
        try:
            await _session.send(input_text)
        except Exception as exc:  # noqa: BLE001 — surface error to client
            yield f"data: {json.dumps({'type': 'error', 'message': str(exc)})}\n\n".encode()
            return

        while True:
            item = await queue.get()
            if item is None:
                break
            if isinstance(item, Exception):
                yield f"data: {json.dumps({'type': 'error', 'message': str(item)})}\n\n".encode()
                break
            if item.type == SessionEventType.TOOL_EXECUTION_START:
                logger.info("tool call: %s", getattr(item.data, "tool_name", "unknown"))
            yield f"data: {json.dumps(item.to_dict())}\n\n".encode()

        yield f"event: done\ndata: {json.dumps({'invocation_id': invocation_id})}\n\n".encode()
    finally:
        with contextlib.suppress(Exception):
            unsubscribe()


# ---------------------------------------------------------------------------
# Invoke Handler
# ---------------------------------------------------------------------------


@app.invoke_handler
async def handle_invoke(request: Request) -> Response:
    try:
        data = await request.json()
        if not isinstance(data, dict):
            raise ValueError("body is not a JSON object")
        input_text = data.get("input")
        if not isinstance(input_text, str) or not input_text.strip():
            raise ValueError('missing or empty "input" field')
    except (json.JSONDecodeError, ValueError):
        return JSONResponse(
            status_code=400,
            content={
                "error": "invalid_request",
                "message": (
                    'Request body must be a JSON object with a non-empty "input" string, '
                    'e.g. {"input": "What can you help me with?"}'
                ),
            },
        )
    return StreamingResponse(
        _stream_response(request.state.invocation_id, input_text),
        media_type="text/event-stream",
        headers={"Cache-Control": "no-cache", "Connection": "keep-alive"},
    )


# ---------------------------------------------------------------------------
# Entrypoint
# ---------------------------------------------------------------------------

if __name__ == "__main__":
    has_token = bool(os.environ.get("GITHUB_TOKEN"))
    has_byok = _init_byok()
    if not has_token and not has_byok:
        sys.exit(
            "Error: Set FOUNDRY_PROJECT_ENDPOINT + MODEL_DEPLOYMENT_NAME "
            "(BYOK Foundry) or GITHUB_TOKEN (GitHub Copilot)."
        )
    logger.info(
        "GHCP SDK + Invocations starting (BYOK=%s, GITHUB_TOKEN=%s)",
        has_byok,
        has_token,
    )
    app.run()
